# ── Pipeline settings ──────────────────────────────────────────
DB_PATH=data/jobs.db
OUTPUT_DIR=data/raw

# Pages per search term (10 results/page on Indeed India)
MAX_PAGES=5

# Polite delay between requests (seconds)
DELAY_MIN=2.0
DELAY_MAX=5.0

# How often to re-scrape (hours)
RUN_INTERVAL_HOURS=6

# ── API server ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
